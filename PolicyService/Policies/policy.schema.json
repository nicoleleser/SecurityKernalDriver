{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "ThreatLockerAssessmentPolicy",
  "type": "object",
  "properties": {
    "FileRules": {
      "type": "array",
      "items": {
        "type": "object",
        "properties": {
          "Pattern": {
            "type": "string",
            "minLength": 1
          },
          "Action": {
            "type": "integer",
            "enum": [ 0, 1 ]
          }
        },
        "required": [ "Pattern", "Action" ],
        "additionalProperties": false
      }
    },
    "IpRules": {
      "type": "array",
      "items": {
        "type": "object",
        "properties": {
          "CidrOrIp": {
            "type": "string",
            "minLength": 1
          },
          "Action": {
            "type": "integer",
            "enum": [ 0, 1 ]
          }
        },
        "required": [ "CidrOrIp", "Action" ],
        "additionalProperties": false
      }
    }
  },
  "required": [ "FileRules", "IpRules" ],
  "additionalProperties": false
}